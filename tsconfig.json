{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./.homeybuild",
    "skipLibCheck": true // Add this to avoid issues with type definitions
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", ".homeybuild"] // Exclude output directories
}